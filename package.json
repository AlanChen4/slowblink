{
  "name": "slowblink",
  "version": "0.2.0",
  "private": true,
  "description": "Periodic screenshot activity tracker with LLM summaries",
  "author": {
    "name": "Alan Chen",
    "email": "avchen4@gmail.com",
    "url": "https://x.com/justmaler"
  },
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlanChen4/slowblink"
  },
  "homepage": "https://github.com/AlanChen4/slowblink",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:app": "electron-vite dev",
    "stripe:listen": "stripe listen --forward-to http://127.0.0.1:55321/functions/v1/stripe-webhook",
    "build": "electron-vite build && node scripts/check-bundle-secrets.js",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "knip": "knip",
    "test": "vitest run",
    "package": "electron-vite build && electron-builder",
    "package:mac": "electron-vite build && electron-builder --mac",
    "icon:build": "bash scripts/build-icon.sh",
    "postinstall": "electron-rebuild -w better-sqlite3",
    "db:start": "supabase start -x realtime,storage-api,imgproxy,mailpit,logflare,vector,supavisor",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff",
    "db:functions:env": "bash scripts/setup-functions-env.sh",
    "db:functions:serve": "pnpm db:functions:env && supabase functions serve --env-file supabase/.env",
    "db:functions:deploy": "supabase functions deploy"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@calcom/cal-sans-ui": "^1.3.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.103.3",
    "ai": "^6.0.156",
    "ai-gateway-provider": "^3.1.3",
    "better-sqlite3": "^12.8.0",
    "electron-store": "^10.0.0",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@electron/rebuild": "^4.0.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.0.2",
    "knip": "^6.3.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supabase": "^2.93.0",
    "tailwind-merge": "^2.5.3",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "supabase"
    ]
  },
  "packageManager": "pnpm@10.29.3+sha256.a74f4dbd3f5a7ca874d004135271f0b697b683bf1fd2fc2133961161cd25b29c"
}
