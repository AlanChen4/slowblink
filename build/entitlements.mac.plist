<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- V8 / JIT: Electron's renderer needs to allocate executable pages. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Electron framework reads DYLD_* env vars during startup. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>

  <!-- AppleScript bridge: read window titles for activity tracking.
       Pairs with NSAppleEventsUsageDescription in electron-builder.yml. -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
</dict>
</plist>
