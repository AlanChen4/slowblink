# Copy to `.env.local` and fill in what you need.
# .env.local is gitignored. If you use Doppler instead, you can ignore this
# file — `doppler run -- pnpm dev` injects everything. See .claude/rules/doppler.md.
#
# ⚠ Values in the "baked into client bundle" section below are statically
# inlined into the Electron app at build time — audited as safe to ship.
# Values in the "runtime only" section are read from process.env at app
# startup; they do NOT get baked in. For dev with dotenv, either use
# Doppler (recommended) or `export` them into the shell before `pnpm dev`.
# `scripts/check-bundle-secrets.js` fails the build if any secret pattern
# sneaks into the shipped bundle.

# --- Baked into client bundle (public / non-sensitive) ---

# Supabase: URL is public, anon key is designed for client distribution
# (RLS protects data). From `pnpm db:start` output or hosted API settings.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Edge function base URL override — non-sensitive dev pointing.
SLOWBLINK_API_BASE=

# --- Runtime only (BYO user keys — never ship these in a build) ---

# Your own OpenAI key; primary input is the Settings UI (stored encrypted
# via safeStorage). Env here is a dev convenience; read at runtime only.
OPENAI_API_KEY=

# Your own Cloudflare AI Gateway credentials, same pattern as above.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_GATEWAY_ID=default
