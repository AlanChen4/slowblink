# Copy to `.env.local` and fill in what you need.
# .env.local is gitignored. If you use Doppler instead, you can ignore this
# file — `doppler run -- pnpm dev` injects everything. See .claude/rules/doppler.md.

# --- Supabase (needed for cloud sync / cloud AI) ---
# From `pnpm db:start` output, or the hosted project's API settings.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Edge function base URL (overrides SUPABASE_URL for dev pointing) ---
SLOWBLINK_API_BASE=

# --- BYO AI keys (only if you're not using cloud AI through Supabase) ---
OPENAI_API_KEY=

# --- Cloudflare AI Gateway (only if routing BYO AI through a gateway) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_GATEWAY_ID=default
