# Copy to `supabase/.env` and fill in before running `supabase start`.
# Loaded by `supabase functions serve --env-file supabase/.env`.

# --- Supabase local stack ---
# SUPABASE_URL and SUPABASE_ANON_KEY are injected automatically when you use
# the CLI locally, but set them here for edge-function consumption.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OAuth providers ---
# Required for Google sign-in to work against the local stack.
# Use the same client credentials you configure in the hosted Supabase project.
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_ID=price_

# --- Cloud AI (Cloudflare AI Gateway → OpenAI) ---
CF_ACCOUNT_ID=
CF_GATEWAY_ID=
CF_AI_TOKEN=
OPENAI_API_KEY=
